          <span ${editingThis?`contenteditable="true" class="editable-active" id="editQ-${i}"`:''}>${isEmpty ? (lang==='en'?'(not written yet)':'(noch nicht geschrieben)') : q}</span>
        </div>
        ${!isEmpty || editingThis ? `<div class="qa-a"><p ${editingThis?`contenteditable="true" class="editable-active" id="editA-${i}"`:''}>${a}</p></div>` : ''}
        ${!editingThis && !isEmpty ? audioControlsHTML(audioKey) : ''}
        ${focusIdx===null ? `<div class="btn-row">
          ${editingThis ? `
            <button class="btn btn-primary" data-saverow="${i}">✓ ${t('save')}</button>
            <button class="btn" data-cancelrow="${i}">${t('cancel')}</button>
          ` : `
            <button class="btn" data-editrow="${i}">✎ ${isEmpty?(lang==='en'?'Write':'Schreiben'):t('edit')}</button>
            <button class="btn btn-danger" data-delete="${i}">${t('delete')}</button>
          `}
        </div>` : ''}
      </div>`;
    }).join('');

  wireAudioControls(list,
    (key)=>{ const i=+key.split('-')[1]; return interviewQ[i][lang].a; },
    (key)=>{ const i=+key.split('-')[1]; return interviewQ[i][lang].a; },
    (key)=>{
      const i=+key.split('-')[1];
      const text = interviewQ[i][lang].a;
      return [{start:0,end:text.length,elId:'qa-item-'+i}];
    }
  );

  list.querySelectorAll('[data-editrow]').forEach(el=>{
    el.onclick = ()=>{
      const i = +el.dataset.editrow;
      qaEditingIdx = i;
      qaDraft = JSON.parse(JSON.stringify(interviewQ[i][lang]));
      renderQaList();
      document.getElementById(`editQ-${i}`).addEventListener('input', e=>{ qaDraft.q = e.target.innerText; });
      document.getElementById(`editA-${i}`).addEventListener('input', e=>{ qaDraft.a = e.target.innerText; });
    };
  });
  list.querySelectorAll('[data-saverow]').forEach(el=>{
    el.onclick = ()=>{
      const i = +el.dataset.saverow;
      interviewQ[i][lang] = qaDraft;
      qaEditingIdx = null;
      saveInterview();
      renderQaList();
    };
  });
  list.querySelectorAll('[data-cancelrow]').forEach(el=>{
    el.onclick = ()=>{ qaEditingIdx = null; renderQaList(); };
  });
  list.querySelectorAll('[data-delete]').forEach(el=>{
    el.onclick = ()=>{
      pendingDelete = {type:'interview', index:+el.dataset.delete};
      document.getElementById('confirmModal').classList.add('show');
    };
  });
}

document.getElementById('confirmYes').onclick = ()=>{
  if(pendingDelete){
    if(pendingDelete.type === 'interview'){
      interviewQ.splice(pendingDelete.index,1);
      saveInterview();
      renderQaList();
    } else if(pendingDelete.type === 'topic'){
      topics.splice(pendingDelete.index,1);
      saveTopics();
      renderStoriesIndex(document.getElementById('app'));
    }
    pendingDelete = null;
  }
  document.getElementById('confirmModal').classList.remove('show');
};
document.getElementById('confirmNo').onclick = ()=>{
  document.getElementById('confirmModal').classList.remove('show');
  pendingDelete = null;
};

document.getElementById('saveNewQ').onclick = ()=>{
  const q = document.getElementById('newQ').value.trim();
  const a = document.getElementById('newA').value.trim();
  if(q && a){
    const item = {en:{q:'',a:''}, de:{q:'',a:''}};
    item[lang] = {q,a};
    interviewQ.push(item);
    saveInterview();
    document.getElementById('newQ').value='';
    document.getElementById('newA').value='';
    document.getElementById('addModal').classList.remove('show');
    renderQaList();
  }
};
document.getElementById('cancelNewQ').onclick = ()=>{
  document.getElementById('addModal').classList.remove('show');
};

document.getElementById('saveNewTopic').onclick = ()=>{
  const enTitle = document.getElementById('newTopicEnTitle').value.trim();
  const deTitle = document.getElementById('newTopicDeTitle').value.trim();
  if(enTitle){
    topics.push({
      en:{title:enTitle, idea:[], story:[], dialogue:[]},
      de:{title:deTitle, idea:[], story:[], dialogue:[]}
    });
    saveTopics();
    document.getElementById('newTopicEnTitle').value='';
    document.getElementById('newTopicDeTitle').value='';
    document.getElementById('addTopicModal').classList.remove('show');
    render();
  }
};
document.getElementById('cancelNewTopic').onclick = ()=>{
  document.getElementById('addTopicModal').classList.remove('show');
};

loadState().then(render);
</script>
</body>
</html>
