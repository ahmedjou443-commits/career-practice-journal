function getPlainText(key, data){
  if(key==='dialogue') return (data.dialogue||[]).map(d=> d.char? `${d.char}: ${d.line}` : d.line).join('\n');
  return (data[key]||[]).join('\n\n');
}
function getAudioText(key, data){
  if(key==='dialogue') return (data.dialogue||[]).map(d=> d.line).join('. ');
  return (data[key]||[]).join(' ');
}
function getSegmentOffsets(key, data, elPrefix){
  const arr = key==='dialogue' ? (data.dialogue||[]) : (data[key]||[]);
  const sep = key==='dialogue' ? '. ' : ' ';
  let pos = 0;
  const offsets = [];
  arr.forEach((item,i)=>{
    const text = key==='dialogue' ? item.line : item;
    const start = pos;
    const end = start + text.length;
    offsets.push({start, end, elId: `${elPrefix}-${i}`});
    pos = end + sep.length;
  });
  return offsets;
}

