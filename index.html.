const audio = { key:null, text:'', charIndex:0, playing:false, loop:false, utter:null };
let watchTimer = null;
let sessionId = 0;
let segmentOffsets = [];

function stopWatch(){ if(watchTimer){ clearInterval(watchTimer); watchTimer = null; } }

function estimateSpeechMs(text){
  const words = text.trim().split(/\s+/).filter(Boolean).length;
  const wordsPerSecond = 2.3;
  return Math.max(2000, (words / wordsPerSecond) * 1000 * 1.7);
}

function watchForFinish(session, hardCutoffMs){
  stopWatch();
  const startedAt = Date.now();
  watchTimer = setInterval(()=>{
    if(session !== sessionId){ stopWatch(); return; }
    updateAutoScroll();
    const elapsed = Date.now() - startedAt;
    if(elapsed < 700) return;
    const naturallyDone = !speechSynthesis.speaking;
    const timedOut = elapsed > hardCutoffMs;
    if(naturallyDone || timedOut){
      stopWatch();
      speechSynthesis.cancel();
      if(audio.loop){
        audio.charIndex = 0;
        setTimeout(()=>speakFrom(0), 80);
      } else {
        audio.playing = false;
        audio.charIndex = 0;
        clearActiveLine();
        renderAudioUI();
      }
    }
  }, 300);
}

function clearActiveLine(){
  document.querySelectorAll('.active-line').forEach(el=>el.classList.remove('active-line'));
}

let lastActiveSegEl = null;
function updateAutoScroll(){
  if(!segmentOffsets.length) return;
  const idx = audio.charIndex;
  let seg = segmentOffsets.find(s => idx >= s.start && idx < s.end);
  if(!seg) seg = segmentOffsets[segmentOffsets.length-1];
  const el = document.getElementById(seg.elId);
  if(!el) return;
  if(el === lastActiveSegEl) return;
  clearActiveLine();
  el.classList.add('active-line');
  el.scrollIntoView({behavior:'smooth', block:'center'});
  lastActiveSegEl = el;
}

function audioToggle(key, text, offsets){
  if(audio.key !== key){
    hardStopAudio();
    audio.key = key;
    audio.text = text;
    audio.charIndex = 0;
    segmentOffsets = offsets || [];
  }
  if(audio.playing){
    sessionId++;
    speechSynthesis.cancel();
    audio.playing = false;
    stopWatch();
  } else {
    audio.playing = true;
    speakFrom(audio.charIndex);
  }
  renderAudioUI();
}

function audioStop(){ hardStopAudio(); renderAudioUI(); }

function audioToggleLoop(key, text, offsets){
  if(audio.key !== key){ audio.key = key; audio.text = text; audio.charIndex = 0; segmentOffsets = offsets || []; }
  audio.loop = !audio.loop;
  renderAudioUI();
}

function hardStopAudio(){
  sessionId++;
  speechSynthesis.cancel();
  audio.playing = false;
  audio.charIndex = 0;
  audio.key = null;
  audio.text = '';
  segmentOffsets = [];
  clearActiveLine();
  lastActiveSegEl = null;
  stopWatch();
}

function speakFrom(charIdx){
  const remaining = audio.text.substring(charIdx);
  if(!remaining.trim()){
    audio.playing = false;
    audio.charIndex = 0;
    clearActiveLine();
    renderAudioUI();
    return;
  }
  sessionId++;
  const mySession = sessionId;
  const u = new SpeechSynthesisUtterance(remaining);
  u.lang = lang==='de' ? 'de-DE' : 'en-US';
  u.rate = 0.95;
  u.onboundary = (e)=>{ if(e.name === 'word'){ audio.charIndex = charIdx + e.charIndex; } };
  audio.utter = u;
  speechSynthesis.speak(u);
  animateWaveform(audio.key);
  watchForFinish(mySession, estimateSpeechMs(remaining));
}

function renderAudioUI(){ render(); }

function animateWaveform(key){
  const wf = document.getElementById('wf-'+key);
  if(!wf) return;
  wf.innerHTML = Array.from({length:16}).map(()=>`<div class="bar" style="height:${audioIsPlaying(key) ? (4+Math.random()*16) : 4}px"></div>`).join('');
  if(audioIsPlaying(key)) setTimeout(()=>animateWaveform(key), 180);
}
function audioIsPlaying(key){ return audio.key === key && audio.playing; }

function audioControlsHTML(key){
  const isPlaying = audioIsPlaying(key);
  const isLoop = audio.key===key && audio.loop;
  return `
    <div class="toolbar" data-audio-toolbar="${key}">
      <button class="tool-btn ${isPlaying?'active':''}" data-act="play" data-key="${key}">${isPlaying?'❚❚ '+t('pause'):'▶ '+t('play')}</button>
      <button class="tool-btn" data-act="stop" data-key="${key}">■ ${t('stop')}</button>
      <button class="tool-btn ${isLoop?'active':''}" data-act="loop" data-key="${key}">↻ ${t('loop')}</button>
      <button class="tool-btn" data-act="transcript" data-key="${key}">≡ ${t('transcript')}</button>
      <div class="waveform" id="wf-${key}"></div>
    </div>
    <div class="transcript-box" id="tb-${key}"></div>
  `;
}

function wireAudioControls(root, audioTextLookup, transcriptTextLookup, offsetsLookup){
  const getTranscript = transcriptTextLookup || audioTextLookup;
  root.querySelectorAll('[data-act]').forEach(el=>{
    const key = el.dataset.key;
    const audioText = audioTextLookup(key);
    const offsets = offsetsLookup ? offsetsLookup(key) : [];
    if(el.dataset.act==='play') el.onclick = ()=>audioToggle(key, audioText, offsets);
    if(el.dataset.act==='stop') el.onclick = ()=>audioStop();
    if(el.dataset.act==='loop') el.onclick = ()=>audioToggleLoop(key, audioText, offsets);
    if(el.dataset.act==='transcript') el.onclick = ()=>{
      const box = document.getElementById('tb-'+key);
      box.classList.toggle('show');
      box.textContent = getTranscript(key);
    };
  });
}

