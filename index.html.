// Claude.ai's window.storage API only exists when this file is viewed live
// inside Claude's own artifact preview. When downloaded and opened as a
// regular file in your own browser, it doesn't exist — so we fall back to
// the browser's built-in localStorage, which works fine for a local file.
const hasCloudStorage = (typeof window.storage !== 'undefined') && window.storage;

async function storageGet(key){
  if(hasCloudStorage){
    try{ return await window.storage.get(key); }catch(e){}
  }
  try{
    const v = localStorage.getItem(key);
    return v !== null ? {value:v} : null;
  }catch(e){ return null; }
}
async function storageSet(key, value){
  if(hasCloudStorage){
    try{ await window.storage.set(key, value); return; }catch(e){}
  }
  try{ localStorage.setItem(key, value); }catch(e){ console.error('save failed', e); }
}

